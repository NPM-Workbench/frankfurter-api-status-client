{
  "name": "frankfurter-api-status-client",
  "description": "A lightweight TypeScript client for monitoring the public status of the Frankfurter API.",
  "type": "module",
  "version": "0.1.0-beta.1",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --coverage --verbose"
  },
  "keywords": [
    "frankfurter-api",
    "frankfurter-api-status",
    "frankfurter-api-monitoring",
    "frankfurter-monitoring",
    "frankfurter-status",
    "frankfurter-status-check",
    "frankfurter-health",
    "frankfurter-api-health",
    "frankfurter-api-health-status"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "msw": "^2.13.6",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "homepage": "https://github.com/NPM-Workbench/frankfurter-api-status-client",
  "bugs": {
    "url": "https://github.com/NPM-Workbench/frankfurter-api-status-client/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NPM-Workbench/frankfurter-api-status-client"
  }
}
